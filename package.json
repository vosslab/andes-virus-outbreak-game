{
	"name": "hantavirus-outbreak-game",
	"version": "0.0.1",
	"private": true,
	"description": "Browser-based Andes virus cruise ship outbreak simulator.",
	"scripts": {
		"build": "./build_github_pages.sh",
		"check": "./check_codebase.sh",
		"serve": "./run_web_server.sh",
		"clean": "./devel/clean_build.sh",
		"test:playwright": "./run_playwright_tests.sh",
		"smoke": "node tests/playwright/smoke_app.mjs",
		"typecheck": "npx tsc --noEmit -p src/tsconfig.json",
		"lint": "npx eslint src/ tests/",
		"format:check": "npx prettier --check '**/*.{ts,tsx,mts,cts,js,mjs,cjs}'",
		"format:write": "npx prettier --write '**/*.{ts,tsx,mts,cts,js,mjs,cjs}'",
		"setup": "./devel/setup_typescript.sh",
		"setup:playwright": "./devel/setup_playwright.sh"
	},
	"devDependencies": {
		"@eslint/js": ">=10.0.1",
		"@types/node": ">=26.1.0",
		"esbuild": ">=0.28.1",
		"eslint": ">=10.6.0",
		"globals": ">=17.7.0",
		"playwright": ">=1.61.1",
		"prettier": ">=3.9.4",
		"tsx": ">=4.22.4",
		"typescript": ">=6.0.3",
		"typescript-eslint": ">=8.62.1"
	},
	"allowScripts": {
		"esbuild@0.28.1": true,
		"fsevents@2.3.2": true,
		"fsevents@2.3.3": true
	}
}
